# VITALIS AI Platform - Environment Configuration
# Copy this to .env.local and fill in your real keys for production expansion

# --- Auth (signup + login; JWT cookie) ---
# Use a long random AUTH_SECRET in production (32+ characters).
# Default user file: <next-app-root>/data/users.json (local). On AWS Lambda, Vercel,
# or cwd under /var/task, defaults to <os.tmpdir>/vitalis-auth/users.json (usually /tmp/...).
# Tmp is writable on Lambda but is not shared across all concurrent instances—use a DB for production.
# AUTH_USE_TMP_DIR=1 forces the tmp path even locally (for testing).
# Optional overrides:
# AUTH_USERS_FILE=C:\data\vitalis-users.json
# AUTH_DATA_DIR=C:\data
# Serverless: omit AUTH_* to auto-use /tmp/vitalis-auth on Lambda/Vercel, or set AUTH_USERS_FILE to a mounted volume.
AUTH_SECRET=vitalis-dev-secret-min-32-characters!!

# --- Video consultation (required for the Video card on the site) ---
# File MUST live next to frontend/package.json (this folder), not the monorepo root.
# After any change: stop and restart `npm run dev` (Next bakes NEXT_PUBLIC_* at startup).
# Zoom/Meet/Teams block in-page embed — use "Open telehealth link" on the Video card.
NEXT_PUBLIC_TELEHEALTH_URL=https://us05web.zoom.us/j/86080004739?pwd=0n2tHXnIRQ74YNPVhbmZ1PMQLHr54u.1

# --- YouTube library (homepage #videos) ---
# Comma-separated video IDs or full youtube.com / youtu.be URLs.
# Optional titles (same number of entries, use | between titles):
# NEXT_PUBLIC_YOUTUBE_VIDEO_LABELS=First title|Second title
# Optional: disease → YouTube video ID for an in-page preview (pairs separated by |, key:id).
# Example (replace IDs with clinician-approved education videos):
# NEXT_PUBLIC_DISEASE_VIDEO_MAP=diabetes:YOUR_VIDEO_ID|asthma:YOUR_OTHER_ID

# AI Core Configuration (Future expansion)
NEXT_PUBLIC_AI_PROVIDER=vitalis_local_node
NEXT_PUBLIC_AI_API_KEY=v_core_placeholder_402

# Backend URL for triage API (FastAPI default :8000)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Branding on PDF health reports (header/footer)
NEXT_PUBLIC_SITE_NAME=VITALIS AI
NEXT_PUBLIC_SITE_URL=https://github.com/pnullas38-wq/aifusion

# Medical Database Synchronization
NEXT_PUBLIC_DB_SYNC_INTERVAL=300000 # 5 minutes

# System Integrity
NEXT_PUBLIC_DEBUG_MODE=false
